; PulseGuard Queue Worker – Supervisor example
; Copy to /etc/supervisor/conf.d/pulseguard.conf (Linux) or equivalent

[program:pulseguard-worker]
process_name=%(program_name)s_%(process_num)02d
command=php /path/to/pulseguard/artisan queue:work database --sleep=3 --tries=3 --max-time=3600
autostart=true
autorestart=true
stopasgroup=true
killasgroup=true
user=www-data
numprocs=2
redirect_stderr=true
stdout_logfile=/path/to/pulseguard/storage/logs/worker.log
stopwaitsecs=3600
